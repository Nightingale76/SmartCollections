{
  "manifest_version": 3,
  "name": "Memora",
  "version": "2.3.2",
  "description": "Memora 智能收藏助手 - 提取、管理和导出多平台收藏内容",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://www.douyin.com/*",
    "https://dashscope.aliyuncs.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Memora"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.xiaohongshu.com/*", "https://www.douyin.com/*"],
      "css": [
        "content/floating-pet.css"
      ],
      "js": [
        "content/page-bridge.js",
        "shared/constants.js",
        "shared/utils.js",
        "shared/qwen-config.js",
        "shared/ai-tags.js",
        "platforms/douyin.js",
        "content/router.js",
        "content/floating-pet.js",
        "content/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/page-bridge.js"],
      "matches": ["https://www.xiaohongshu.com/*"]
    }
  ],
  "background": {
    "service_worker": "shared/background.js"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
