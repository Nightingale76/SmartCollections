{
  "manifest_version": 3,
  "name": "memora",
  "version": "1.0.1",
  "description": "Memora 智能收藏助手 - 提取、分类、检索和导出多平台收藏内容"
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://www.douyin.com/*",
    "https://dashscope.aliyuncs.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*",
        "https://www.douyin.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["https://www.xiaohongshu.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
